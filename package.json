{
  "name": "westernloss-modern-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "sanity:dev": "sanity dev --port 3333",
    "sanity:deploy": "sanity deploy",
    "sanity:import:members": "sanity exec scripts/import-member-companies.ts --with-user-token",
    "sanity:import:news": "sanity exec scripts/import-news-posts.ts --with-user-token",
    "sanity:mirror:news-images": "sanity exec scripts/mirror-news-images.ts --with-user-token",
    "sanity:seed:pages": "sanity exec scripts/seed-managed-pages.ts --with-user-token",
    "sanity:fix:news-keys": "sanity exec scripts/fix-news-album-keys.ts --with-user-token"
  },
  "dependencies": {
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^4.22.0",
    "next": "16.1.6",
    "next-sanity": "^11.6.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "sanity": "^4.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
